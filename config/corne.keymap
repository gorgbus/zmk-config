#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    behaviors {
        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            quick-tap-ms = <0>;
            flavor = "tap-preferred";
            bindings = <&kp>, <&kp>;

            quick-tap-ms = <180>;
            global-quick-tap;
        };

        ltq: ltq {
            compatible = "zmk,behavior-hold-tap";
            label = "LTQ";
            bindings = <&mo>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <600>;
            global-quick-tap;
            quick-tap-ms = <400>;
        };
    };

    combos { compatible = "zmk,combos"; };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp EQUAL      &kp Q           &kp W           &kp E        &kp R             &kp T      &kp Z          &kp U         &kp I        &kp O           &kp P               &kp C_PREV
&kp LS(EQUAL)  &hm LEFT_GUI A  &hm LEFT_ALT S  &hm LCTRL D  &hm LEFT_SHIFT F  &kp G      &kp H          &hm RSHIFT J  &hm RCTRL K  &hm LEFT_ALT L  &hm RGUI SEMICOLON  &kp C_PLAY_PAUSE
&kp LSHFT      &kp Y           &kp X           &kp C        &kp V             &kp B      &kp N          &kp M         &kp COMMA    &kp DOT         &kp FSLH            &kp C_NEXT
                                               &kp TAB      &lt 2 ESCAPE      &kp SPACE  &kp BACKSPACE  &lt 1 ENTER   &sl 3
            >;
        };

        lower_layer {
            bindings = <
&kp TAB  &kp N1           &kp N2           &kp N3           &kp N4           &kp N5           &kp N6           &kp N7           &kp N8           &kp N9           &kp N0           &kp BSPC
&trans   &kp KP_NUMBER_1  &kp KP_NUMBER_2  &kp KP_NUMBER_3  &kp KP_NUMBER_4  &kp KP_NUMBER_5  &kp KP_NUMBER_6  &kp KP_NUMBER_7  &kp KP_NUMBER_8  &kp KP_NUMBER_9  &kp KP_NUMBER_0  &trans
&trans   &trans           &trans           &trans           &kp UP_ARROW     &kp DOWN_ARROW   &kp LEFT_ARROW   &kp RIGHT_ARROW  &trans           &trans           &trans           &trans
                                           &trans           &trans           &trans           &trans           &trans           &trans
            >;
        };

        raise_layer {
            bindings = <
&trans  &kp RA(GRAVE)         &kp RA(COMMA)  &kp RA(DOT)   &kp KP_MINUS  &kp RA(W)      &kp RA(NUMBER_6)  &kp RA(B)              &kp RA(N)          &kp RA(SEMICOLON)  &kp RA(Q)          &trans
&trans  &kp LS(SINGLE_QUOTE)  &kp RA(SLASH)  &kp KP_SLASH  &kp KP_EQUAL  &kp RA(C)      &kp RA(X)         &kp LS(RIGHT_BRACKET)  &kp RIGHT_BRACKET  &kp GRAVE          &kp LS(SEMI)       &trans
&trans  &kp RA(A)             &kp KP_PLUS    &kp RA(F)     &kp RA(G)     &kp LS(MINUS)  &kp RA(V)         &kp LS(DOT)            &kp COMMA          &kp DOT            &kp LS(BACKSLASH)  &trans
                                             &trans        &trans        &trans         &trans            &trans                 &trans
            >;
        };

        layer_3 {
            bindings = <
&trans  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &bt BT_CLR    &trans        &trans        &trans        &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans        &trans        &trans        &trans        &trans  &to 4   &trans  &trans  &trans  &trans  &trans
                                    &trans        &trans        &trans  &trans  &trans  &trans
            >;
        };

        gaming {
            bindings = <
&trans                  &kp TAB         &kp Q  &kp W  &kp E      &kp R  &kp F1  &kp F2  &kp F3  &kp F4  &kp F5   &trans
&hm LEFT_ALT LS(EQUAL)  &kp LCTRL       &kp A  &kp S  &kp D      &kp F  &kp F6  &kp F7  &kp F8  &kp F9  &kp F10  &trans
&kp ESCAPE              &kp LEFT_SHIFT  &kp Z  &kp X  &kp C      &kp M  &trans  &trans  &trans  &trans  &trans   &trans
                                               &kp V  &kp SPACE  &mo 5  &trans  &trans  &to 0
            >;
        };

        gaming_2 {
            bindings = <
&trans  &kp NUMBER_1  &kp NUMBER_2  &trans  &kp NUMBER_3  &kp NUMBER_4  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans        &trans        &trans  &trans        &kp NUMBER_5  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans        &trans        &kp N8  &kp N7        &kp NUMBER_6  &trans  &trans  &trans  &trans  &trans  &trans
                                    &trans  &trans        &trans        &trans  &trans  &trans
            >;
        };
    };
};
